{
  "name": "@liblaf/github-bot",
  "description": "",
  "version": "0.1.7",
  "type": "module",
  "files": [
    "dist"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "keywords": [],
  "homepage": "https://github.com/liblaf/github-bot",
  "bugs": {
    "url": "https://github.com/liblaf/github-bot/issues"
  },
  "license": "MIT",
  "author": {
    "name": "liblaf",
    "url": "https://github.com/liblaf",
    "email": "30631553+liblaf@users.noreply.github.com"
  },
  "bin": {},
  "repository": "github:liblaf/github-bot",
  "funding": {
    "url": "https://github.com/liblaf/github-bot?sponsor=1",
    "type": "github"
  },
  "scripts": {
    "build": "bunup",
    "dev-proxy": "smee --port 8787 --path '/api/github/webhooks'",
    "dev": "wrangler dev --port 8787",
    "format:fix": "biome format --write",
    "format": "biome format",
    "generate-types": "wrangler types --env-file '.dev.vars.example' --env-interface 'CloudflareBindings'",
    "lint:fix": "biome check --write",
    "lint": "biome check",
    "prepack": "bun run build",
    "prepare": "bun run generate-types",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "test": "bun test",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/webhooks": "^14.2.0",
    "hono": "^4.12.9",
    "octokit": "^5.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@liblaf/config": "^0.1.3",
    "@types/node": "^25.5.0",
    "bunup": "^0.16.31",
    "smee-client": "^5.0.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.78.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "readme": "./README.md"
